rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidTrade(data) {
      return data.keys().hasAll(['userId', 'symbol', 'entryPrice', 'exitPrice', 'quantity', 'pnl', 'createdAt'])
        && data.userId == request.auth.uid
        && data.symbol is string && data.symbol.size() <= 20
        && data.entryPrice is number && data.entryPrice >= 0
        && data.exitPrice is number && data.exitPrice >= 0
        && data.quantity is number && data.quantity > 0
        && data.pnl is number
        && data.createdAt is timestamp;
    }

    function isValidChecklist(data) {
      return data.keys().hasAll(['userId', 'date', 'disciplineScore', 'createdAt'])
        && data.userId == request.auth.uid
        && data.date is string && data.date.size() == 10
        && data.disciplineScore is number && data.disciplineScore >= 0 && data.disciplineScore <= 100
        && data.createdAt is timestamp;
    }

    function isValidInsight(data) {
      return data.keys().hasAll(['userId', 'type', 'period', 'content', 'createdAt'])
        && data.userId == request.auth.uid
        && data.type in ['DAILY', 'WEEKLY']
        && data.content is string && data.content.size() <= 10000
        && data.createdAt is timestamp;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['userId'])
        && data.userId == request.auth.uid
        && (data.dailyLossLimit == null || data.dailyLossLimit is number)
        && (data.singleTradeLossLimit == null || data.singleTradeLossLimit is number);
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      
      match /trades/{tradeId} {
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTrade(incoming());
        allow update: if isOwner(userId) && isValidTrade(incoming()) 
          && incoming().userId == existing().userId
          && incoming().createdAt == existing().createdAt;
        allow delete: if isOwner(userId);
      }

      match /checklists/{checklistId} {
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChecklist(incoming());
        allow update: if isOwner(userId) && isValidChecklist(incoming());
        allow delete: if isOwner(userId);
      }

      match /insights/{insightId} {
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidInsight(incoming());
        allow update: if isOwner(userId) && isValidInsight(incoming());
        allow delete: if isOwner(userId);
      }

      match /settings/current {
        allow get: if isOwner(userId);
        allow write: if isOwner(userId) && isValidSettings(incoming());
      }
    }
  }
}
